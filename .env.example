# ============================================
# ChatApp — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================

# App
APP_NAME=chatapp
APP_URL=http://localhost:3000
NODE_ENV=development

# Server
SERVER_PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://chatapp:chatapp_dev_2026@localhost:5432/chatapp

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_very_long_random_string
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_very_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/oauth/google/callback

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/oauth/github/callback

# Stripe (Phase 4)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=

# Tenor GIF API (Phase 4)
TENOR_API_KEY=

# Upload
UPLOAD_DIR=./uploads
MAX_IMAGE_SIZE=5242880
MAX_FILE_SIZE=104857600

# Rate Limiting
RATE_LIMIT_GUEST_MS=10000
RATE_LIMIT_USER_MS=1000

# LCEN — Durée de rétention des logs (jours)
LCEN_RETENTION_DAYS=365
